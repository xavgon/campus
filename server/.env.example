NODE_ENV=development
PORT=3001

# mTLS — Task 1
# true  = exige certificado de cliente (produção; sem excepção automática de localhost)
# false = em dev permite localhost sem cert (proxy Vite)
# Omitido: true em NODE_ENV=production, false em development
MTLS_STRICT=false

# Task 4 — só aceita dispositivos com cert registado na CA (além de válido pela CA)
CA_REQUIRE_REGISTRATION=false

# PostgreSQL
# Neon (São Paulo): usar connection string do dashboard (sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Uploads
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

# FFmpeg — caminho para o executável
# Windows: C:\Users\<user>\AppData\Local\Microsoft\WinGet\Packages\Gyan.FFmpeg_...\bin\ffmpeg.exe
# Linux/Mac: ffmpeg
FFMPEG_PATH=ffmpeg

# CORS — em dev aceita localhost em qualquer porta (5173, 5174, …)
# O cliente Electron empacotado usa origem campus:// (aceite automaticamente)
CLIENT_URL=http://localhost:5173

# SMTP — reset de password por email
# Sem SMTP_HOST, o link de reset é impresso no log do servidor (útil em dev)
# Exemplo Gmail (requer palavra-passe de aplicação): smtp.gmail.com / 587 / secure=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CAMPUS <noreply@campus.co.ao>
